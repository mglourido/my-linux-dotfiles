#seguridad, por si se cuelan archivos no deseados
*.exe
*.AppImage
*.tar.gz
*.pdf
*.zip
*.PKGINFO


# Ajustes/estado/secretos de usuario de AGS: movidos a ~/.config/gigios/, fuera del
# repo (bin/link.sh los migra; ver hypr/SETUP.md §14). config/ ya no forma parte del
# repo — se ignora para que dispositivos que aún lo tengan no lo vuelvan a añadir.
ags/config/

# Logs de runtime
hypr/logs/

# jarvis: datos privados del launcher (repos detectados) — no versionar
jarvis/

# Estado y sesiones del launcher orion — datos por-usuario, no versionar.
# El directorio lo crea bin/link.sh si falta (no hace falta versionarlo).
state/orion/

# Copias archivadas sin uso (código muerto)
_legacy/

# Snapshots de migración
preflight-snapshot.txt

# Cache / datos de runtime por-usuario — no versionar.
# Los subdirectorios los crea bin/link.sh si faltan (marcados CREATABLE).
cache/

# Foto de perfil: mecanismo viejo eliminado (ahora estandarizada en
# ~/.cache/gigios/face.png, ver hypr/SETUP.md §13). Se ignoran para que los
# dispositivos que todavía los tienen en disco no los vuelvan a añadir.
# (fotoPerfil.txt queda cubierto por `ags/config/` de arriba.)
hypr/hyprlock_avatar.png
assets/face.png

# Metadatos de escritorio
**/.directory

# GiGiOS — alias estable para la iGPU Intel (laptop híbrida Intel + NVIDIA).
#
# Los nodos /dev/dri/cardN se intercambian entre reinicios (un arranque
# card1=Intel, otro card1=NVIDIA), lo que rompe AQ_DRM_DEVICES de Hyprland.
# La dirección PCI de la Intel (0000:00:02.0) SÍ es estable, así que le damos
# un nombre fijo y sin ':' (AQ_DRM_DEVICES usa ':' como separador):
#   /dev/dri/gigios-igpu  ->  siempre la Intel
#
# Instalar:
#   sudo cp ~/GiGiOS/hypr/gpu/99-gigios-igpu.rules /etc/udev/rules.d/
#   sudo udevadm control --reload && sudo udevadm trigger
# Verificar:
#   readlink -f /dev/dri/gigios-igpu   # debe resolver al card de la Intel (i915)

SUBSYSTEM=="drm", KERNEL=="card[0-9]", KERNELS=="0000:00:02.0", SYMLINK+="dri/gigios-igpu"
